NODE_ENV=production
PORT=3000

# Security
JWT_SECRET=replace-with-a-long-random-secret
ENABLE_CSP=true
CSP_REPORT_ONLY=true

# Database
DB_HOST=your-db-host
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=your_db_name
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true
DB_CONNECT_TIMEOUT_MS=10000

# CORS / Public URL
CORS_ORIGIN=https://your-frontend-domain.com
PUBLIC_APP_URL=https://your-frontend-domain.com

# Maintenance
MAINTENANCE_MODE=false

# Hosting mode (Render API + externally hosted frontend/images)
SERVE_FRONTEND=false
SERVE_UPLOADS=false
UPLOADS_ENABLED=false

# Email (IONOS SMTP)
SMTP_HOST=smtp.ionos.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=security@your-domain.com
SMTP_PASS=your-ionos-smtp-password
SMTP_FROM=security@your-domain.com

# Rate limiting (cost protection)
RATE_LIMIT_WINDOW_MS=300000
RATE_LIMIT_API_MAX=100
RATE_LIMIT_CONTACT_MAX=30
RATE_LIMIT_FORGOT_MAX=10
RATE_LIMIT_RESET_MAX=20
RATE_LIMIT_MEDIA_MAX=40
